---
const services = [
  { icon: '🔧', name: 'Plumbing', desc: 'Leaks, clogs, water heaters & full installations' },
  { icon: '⚡', name: 'Electrical', desc: 'Panel upgrades, wiring, outlets & permits' },
  { icon: '❄️', name: 'HVAC', desc: 'AC repair, furnace install & tune-ups' },
  { icon: '🏠', name: 'Roofing', desc: 'Repairs, replacements & storm damage' },
  { icon: '🎨', name: 'Painting', desc: 'Interior & exterior, cabinet refinishing' },
  { icon: '🔨', name: 'Remodeling', desc: 'Kitchen, bath, basement & additions' },
  { icon: '🌿', name: 'Landscaping', desc: 'Lawn care, hardscaping & design' },
  { icon: '🪵', name: 'Flooring', desc: 'Hardwood, tile, LVP & carpet' },
  { icon: '🏗️', name: 'General Contractor', desc: 'Full project management' },
];
const stats = [
  { value: '50,000+', label: 'Homeowners Helped' },
  { value: '2,800+', label: 'Verified Contractors' },
  { value: 'All 50', label: 'States Covered' },
  { value: '4.8 ★', label: 'Average Rating' },
];
const steps = [
  { n: '1', title: 'Tell Us What You Need', desc: 'Select your service type, describe your project, and share your zip code.' },
  { n: '2', title: 'Get Matched Instantly', desc: 'We connect you with pre-screened local contractors available in your area.' },
  { n: '3', title: 'Compare & Hire', desc: 'Review profiles, read verified reviews, and choose the right pro for the job.' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>The Contractor Services — Find Trusted Local Contractors</title>
  <meta name="description" content="Get matched with pre-screened local contractors for plumbing, electrical, HVAC, roofing, remodeling and more. Free service for homeowners across the US." />
  <link rel="canonical" href="https://thecontractorservices.com/" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        container: { center: true, padding: '1rem', screens: { '2xl': '1280px' } },
        extend: {
          colors: { brand: '#1B3A5C', accent: '#F97316', light: '#F8F6F1' },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            display: ['Sora', 'Inter', 'sans-serif'],
          },
        },
      },
    };
  </script>
  <style>
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    .btn-primary { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; border-radius: 0.75rem; padding: 1rem 2rem; font-size: 1rem; font-weight: 600; color: white; background: #F97316; transition: all .2s; box-shadow: 0 4px 14px rgba(249,115,22,0.4); }
    .btn-primary:hover { background: #ea6c0c; box-shadow: 0 8px 20px rgba(249,115,22,0.45); transform: translateY(-1px); }
    .btn-outline { display: inline-flex; align-items: center; justify-content: center; border-radius: 0.75rem; padding: 1rem 2rem; font-size: 1rem; font-weight: 600; color: white; border: 2px solid rgba(255,255,255,0.4); transition: all .2s; }
    .btn-outline:hover { background: rgba(255,255,255,0.1); }
    .card { background: white; border-radius: 1rem; border: 1px solid #e5e7eb; padding: 1.25rem; transition: all .2s; }
    .card:hover { border-color: #F97316; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
    input, select, textarea { width: 100%; border-radius: 0.75rem; border: 1px solid #e5e7eb; padding: 0.75rem 1rem; font-size: 0.95rem; outline: none; font-family: inherit; transition: border-color .15s; }
    input:focus, select:focus, textarea:focus { border-color: #F97316; box-shadow: 0 0 0 3px rgba(249,115,22,0.15); }
    .step-circle { width: 3.5rem; height: 3.5rem; border-radius: 50%; background: #1B3A5C; display: flex; align-items: center; justify-content: center; color: white; font-family: 'Sora', sans-serif; font-size: 1.25rem; font-weight: 700; box-shadow: 0 4px 14px rgba(27,58,92,0.35); margin: 0 auto 1.25rem; }
  </style>
</head>
<body style="background:#fff; color:#1f2937;">

  <!-- NAV -->
  <header style="background:#1B3A5C; position:sticky; top:0; z-index:50; box-shadow:0 2px 12px rgba(0,0,0,0.15);">
    <div class="container" style="display:flex; height:4rem; align-items:center; justify-content:space-between;">
      <a href="/" style="display:flex; align-items:center; gap:0.625rem; text-decoration:none;">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="14" fill="#F97316"/><path d="M8 14.5l4 4 8-9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:700; color:white;">The Contractor Services</span>
      </a>
      <a href="#request" class="btn-primary" style="padding:0.6rem 1.25rem; font-size:0.875rem; display:none;" id="nav-cta">Get Free Quotes</a>
    </div>
  </header>
  <script>document.getElementById('nav-cta').style.display = window.innerWidth >= 640 ? 'inline-flex' : 'none';</script>

  <!-- HERO -->
  <section style="position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; z-index:0;">
      <img src="/images/hero.webp" alt="Beautifully renovated kitchen" style="width:100%; height:100%; object-fit:cover;" />
      <div style="position:absolute; inset:0; background:rgba(27,58,92,0.78);"></div>
    </div>
    <div class="container" style="position:relative; z-index:1; padding-top:5rem; padding-bottom:5rem; text-align:center; color:white;">
      <div style="display:inline-block; margin-bottom:1rem; border-radius:9999px; background:rgba(255,255,255,0.15); padding:0.375rem 1rem; font-size:0.875rem; font-weight:500;">
        ✅ Free for Homeowners &mdash; No Commitment Required
      </div>
      <h1 style="font-family:'Sora',sans-serif; font-size:clamp(2rem,5vw,3.5rem); font-weight:800; line-height:1.15; max-width:52rem; margin:0 auto;">
        Find a Trusted Contractor<br/>in Your Area
      </h1>
      <p style="margin-top:1.25rem; font-size:1.125rem; color:rgba(255,255,255,0.85); max-width:40rem; margin-left:auto; margin-right:auto;">
        Tell us what you need. We'll match you with pre-screened local professionals — fast, free, and no obligation.
      </p>
      <div style="margin-top:2.5rem; display:flex; flex-wrap:wrap; justify-content:center; gap:0.75rem;">
        <a href="#request" class="btn-primary">Find Contractors Near Me</a>
        <a href="#how-it-works" class="btn-outline">How It Works</a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section style="background:#F97316; padding:2rem 0;">
    <div class="container">
      <dl style="display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; text-align:center; color:white;">
        {stats.map(s => (
          <div>
            <dd style="font-family:'Sora',sans-serif; font-size:1.875rem; font-weight:800;">{s.value}</dd>
            <dt style="margin-top:0.25rem; font-size:0.875rem; opacity:0.85;">{s.label}</dt>
          </div>
        ))}
      </dl>
    </div>
  </section>
  <style>@media(min-width:768px){dl.stats{grid-template-columns:repeat(4,1fr)!important}}</style>
  <script>document.querySelector('dl')?.classList.add('stats');</script>

  <!-- SERVICES -->
  <section style="padding:4rem 0; background:#F8F6F1;" id="services">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <h2 style="font-family:'Sora',sans-serif; font-size:clamp(1.75rem,3vw,2.5rem); font-weight:800; color:#1B3A5C;">What Are You Looking For?</h2>
        <p style="margin-top:0.75rem; color:#6b7280; max-width:40rem; margin-left:auto; margin-right:auto;">From emergency repairs to full renovations, we connect homeowners with vetted local pros for every project.</p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:1rem;">
        {services.map(s => (
          <a href="#request" class="card" style="text-decoration:none; display:flex; flex-direction:column; gap:0.75rem;">
            <span style="font-size:1.75rem;">{s.icon}</span>
            <div>
              <h3 style="font-weight:600; color:#1B3A5C; font-size:0.95rem;">{s.name}</h3>
              <p style="font-size:0.825rem; color:#9ca3af; margin-top:0.25rem; line-height:1.4;">{s.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <style>@media(min-width:640px){.services-grid{grid-template-columns:repeat(3,1fr)!important}}</style>

  <!-- HOW IT WORKS -->
  <section style="padding:4rem 0; background:white;" id="how-it-works">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <h2 style="font-family:'Sora',sans-serif; font-size:clamp(1.75rem,3vw,2.5rem); font-weight:800; color:#1B3A5C;">How It Works</h2>
        <p style="margin-top:0.75rem; color:#6b7280; max-width:36rem; margin-left:auto; margin-right:auto;">Getting connected to the right contractor takes less than two minutes.</p>
      </div>
      <div style="display:grid; gap:2rem; max-width:56rem; margin:0 auto;">
        {steps.map(s => (
          <div style="text-align:center; padding:1.5rem;">
            <div class="step-circle">{s.n}</div>
            <h3 style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:700; color:#1B3A5C; margin-bottom:0.5rem;">{s.title}</h3>
            <p style="color:#6b7280; font-size:0.9rem; line-height:1.6;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <style>@media(min-width:768px){.steps-grid{grid-template-columns:repeat(3,1fr)!important}}</style>

  <!-- PHOTOS -->
  <section style="display:grid; max-height:18rem; overflow:hidden;">
    <div style="display:grid; grid-template-columns:1fr 1fr;">
      <img src="/images/exterior.webp" alt="Professionally renovated home exterior" style="width:100%; height:18rem; object-fit:cover;" />
      <img src="/images/bathroom.webp" alt="Beautifully remodeled bathroom" style="width:100%; height:18rem; object-fit:cover;" />
    </div>
  </section>

  <!-- FORM -->
  <section style="padding:4rem 0; background:#F8F6F1;" id="request">
    <div class="container" style="max-width:42rem;">
      <div style="text-align:center; margin-bottom:2.5rem;">
        <h2 style="font-family:'Sora',sans-serif; font-size:clamp(1.75rem,3vw,2.25rem); font-weight:800; color:#1B3A5C;">Get Free Quotes From Local Pros</h2>
        <p style="margin-top:0.75rem; color:#6b7280;">Tell us what you need and we'll match you with available contractors in your area — completely free.</p>
      </div>
      <div style="background:white; border-radius:1.5rem; box-shadow:0 8px 40px rgba(0,0,0,0.1); padding:2.5rem;">
        <form id="request-form" style="display:flex; flex-direction:column; gap:1.25rem;">
          <div>
            <label style="display:block; font-size:0.875rem; font-weight:600; color:#374151; margin-bottom:0.5rem;">What service do you need? <span style="color:#F97316;">*</span></label>
            <select name="service" required>
              <option value="">Select a service...</option>
              <option>Plumbing</option>
              <option>Electrical</option>
              <option>HVAC / Air Conditioning</option>
              <option>Roofing</option>
              <option>Interior Painting</option>
              <option>Exterior Painting</option>
              <option>Kitchen Remodeling</option>
              <option>Bathroom Remodeling</option>
              <option>Flooring</option>
              <option>Landscaping</option>
              <option>General Contractor</option>
              <option>Pest Control</option>
              <option>Other</option>
            </select>
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div>
              <label style="display:block; font-size:0.875rem; font-weight:600; color:#374151; margin-bottom:0.5rem;">Your Name <span style="color:#F97316;">*</span></label>
              <input name="name" type="text" placeholder="Jane Smith" required />
            </div>
            <div>
              <label style="display:block; font-size:0.875rem; font-weight:600; color:#374151; margin-bottom:0.5rem;">ZIP Code <span style="color:#F97316;">*</span></label>
              <input name="zip" type="text" placeholder="55401" inputmode="numeric" maxlength="5" required />
            </div>
          </div>
          <div>
            <label style="display:block; font-size:0.875rem; font-weight:600; color:#374151; margin-bottom:0.5rem;">Email Address <span style="color:#F97316;">*</span></label>
            <input name="email" type="email" placeholder="jane@example.com" required />
          </div>
          <div>
            <label style="display:block; font-size:0.875rem; font-weight:600; color:#374151; margin-bottom:0.5rem;">Briefly describe your project</label>
            <textarea name="message" rows="3" placeholder="E.g. I need my bathroom faucet replaced and there's a slow drain..." style="resize:none;"></textarea>
          </div>
          <button type="submit" class="btn-primary" style="width:100%; font-size:1rem; padding:1.1rem 2rem;">
            Find Contractors in My Area →
          </button>
          <p style="font-size:0.75rem; text-align:center; color:#9ca3af;">By submitting, you agree to receive contractor quotes via email. We never sell your data.</p>
        </form>
        <div id="success-msg" style="display:none; text-align:center; padding:3rem 1rem;">
          <div style="font-size:3rem; margin-bottom:1rem;">✅</div>
          <h3 style="font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:800; color:#1B3A5C; margin-bottom:0.75rem;">You're All Set!</h3>
          <p style="color:#6b7280;">We're matching you with contractors in your area. You'll hear back within 24 hours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section style="padding:3rem 0; background:white; border-top:1px solid #f3f4f6;">
    <div class="container">
      <div style="display:flex; flex-wrap:wrap; justify-content:center; align-items:center; gap:2.5rem; text-align:center;">
        {[
          { icon: '🔒', t: '100% Free', s: 'No Obligation' },
          { icon: '✅', t: 'Pre-Screened', s: 'Contractors' },
          { icon: '⭐', t: 'Verified', s: 'Reviews' },
          { icon: '⚡', t: 'Fast', s: 'Matching' },
          { icon: '🇺🇸', t: 'All 50 States', s: 'Covered' },
        ].map(b => (
          <div style="display:flex; flex-direction:column; align-items:center; gap:0.25rem;">
            <span style="font-size:1.75rem;">{b.icon}</span>
            <span style="font-size:0.75rem; font-weight:600; color:#374151;">{b.t}</span>
            <span style="font-size:0.75rem; color:#9ca3af;">{b.s}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="background:#1B3A5C; color:white; padding:2.5rem 0;">
    <div class="container" style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:1rem;">
      <div style="display:flex; align-items:center; gap:0.5rem;">
        <svg width="20" height="20" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="14" fill="#F97316"/><path d="M8 14.5l4 4 8-9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="font-weight:600; font-size:0.9rem;">The Contractor Services</span>
      </div>
      <p style="color:rgba(255,255,255,0.5); font-size:0.75rem;">&copy; {new Date().getFullYear()} TheContractorServices.com. All rights reserved.</p>
      <nav style="display:flex; gap:1.25rem;">
        <a href="/privacy" style="color:rgba(255,255,255,0.55); font-size:0.75rem; text-decoration:none; transition:color .15s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">Privacy Policy</a>
        <a href="/terms" style="color:rgba(255,255,255,0.55); font-size:0.75rem; text-decoration:none; transition:color .15s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">Terms of Service</a>
        <a href="#request" style="color:rgba(255,255,255,0.55); font-size:0.75rem; text-decoration:none; transition:color .15s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">Get Quotes</a>
      </nav>
    </div>
  </footer>

  <script>
    const form = document.getElementById('request-form');
    const successMsg = document.getElementById('success-msg');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('[type=submit]');
      btn.disabled = true;
      btn.textContent = 'Submitting…';
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('https://formspree.io/f/xwkgzqqk', {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } catch {}
      form.style.display = 'none';
      successMsg.style.display = 'block';
    });
    // Make stats grid responsive
    const dl = document.querySelector('dl');
    if(dl && window.innerWidth >= 768) dl.style.gridTemplateColumns = 'repeat(4,1fr)';
    // Make services grid 3-col on desktop
    const sg = document.querySelector('#services > div > div[style*="grid"]');
    if(sg && window.innerWidth >= 640) sg.style.gridTemplateColumns = 'repeat(3,1fr)';
    // Make steps 3-col on desktop
    const stg = document.querySelector('#how-it-works > div > div[style*="grid"]');
    if(stg && window.innerWidth >= 768) stg.style.gridTemplateColumns = 'repeat(3,1fr)';
  </script>
</body>
</html>
