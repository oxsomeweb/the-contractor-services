---
const services = [
  { icon: '🔧', name: 'Plumbing', desc: 'Leaks, clogs, water heaters & full installations' },
  { icon: '⚡', name: 'Electrical', desc: 'Panel upgrades, wiring, outlets & more' },
  { icon: '❄️', name: 'HVAC', desc: 'AC repair, furnace install, tune-ups' },
  { icon: '🏠', name: 'Roofing', desc: 'Repairs, replacements & storm damage' },
  { icon: '🎨', name: 'Painting', desc: 'Interior & exterior, cabinet refinishing' },
  { icon: '🔨', name: 'Remodeling', desc: 'Kitchen, bath, basement & additions' },
  { icon: '🌿', name: 'Landscaping', desc: 'Lawn care, hardscaping & design' },
  { icon: '🪵', name: 'Flooring', desc: 'Hardwood, tile, LVP & carpet' },
  { icon: '🏗️', name: 'General Contractor', desc: 'Full project management & coordination' },
];

const stats = [
  { value: '50,000+', label: 'Homeowners Helped' },
  { value: '2,800+', label: 'Verified Contractors' },
  { value: 'All 50', label: 'States Covered' },
  { value: '4.8 ★', label: 'Average Rating' },
];

const steps = [
  { n: '1', title: 'Tell Us What You Need', desc: 'Select your service type, describe your project, and share your zip code.' },
  { n: '2', title: 'Get Matched Instantly', desc: 'We connect you with pre-screened local contractors available in your area.' },
  { n: '3', title: 'Compare & Hire', desc: 'Review profiles, read real reviews, and choose the right pro for the job.' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>The Contractor Services — Find Trusted Local Contractors</title>
  <meta name="description" content="Get matched with pre-screened local contractors for plumbing, electrical, HVAC, roofing, remodeling and more. Free service for homeowners across the US." />
  <link rel="canonical" href="https://thecontractorservices.com/" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"WebSite","name":"The Contractor Services","url":"https://thecontractorservices.com","potentialAction":{"@type":"SearchAction","target":"https://thecontractorservices.com/#request","query-input":"required name=service_type"}}
  </script>
</head>
<body>

  <!-- NAV -->
  <header class="sticky top-0 z-50 bg-brand shadow-sm">
    <div class="container flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="14" fill="#F97316"/><path d="M8 14.5l4 4 8-9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="font-display text-lg font-bold text-white">The Contractor Services</span>
      </a>
      <a href="#request" class="btn-primary hidden sm:inline-flex py-2 px-5 text-sm">Get Free Quotes</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img src="/images/hero.webp" alt="Beautifully renovated home kitchen" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-brand/75"></div>
    </div>
    <div class="container py-20 md:py-28 text-center text-white">
      <div class="inline-block mb-4 rounded-full bg-white/15 px-4 py-1.5 text-sm font-medium text-white">
        ✅ Free for Homeowners — No Commitment Required
      </div>
      <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight max-w-4xl mx-auto leading-tight">
        Find a Trusted Contractor<br class="hidden md:block" /> in Your Area
      </h1>
      <p class="mt-6 text-lg md:text-xl text-white/85 max-w-2xl mx-auto">
        Tell us what you need. We'll match you with pre-screened local professionals — fast, free, and no obligation.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href="#request" class="btn-primary text-base">Find Contractors Near Me</a>
        <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-semibold text-white border-2 border-white/40 hover:bg-white/10 transition-all">How It Works</a>
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-accent py-8">
    <div class="container">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
        {stats.map(s => (
          <div>
            <dd class="font-display text-3xl font-bold">{s.value}</dd>
            <dt class="mt-1 text-sm font-medium text-white/80">{s.label}</dt>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-16 md:py-20 bg-light" id="services">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="section-title">What Are You Looking For?</h2>
        <p class="mt-3 text-gray-500 max-w-xl mx-auto">From emergency repairs to full renovations, we connect homeowners with vetted local pros for every project.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-4">
        {services.map(s => (
          <a href="#request" class="group flex flex-col items-start gap-3 rounded-2xl border border-gray-200 bg-white p-5 hover:border-accent hover:shadow-md transition-all">
            <span class="text-3xl">{s.icon}</span>
            <div>
              <h3 class="font-semibold text-brand group-hover:text-accent transition-colors">{s.name}</h3>
              <p class="text-sm text-gray-500 mt-1">{s.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 md:py-20 bg-white" id="how-it-works">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="section-title">How It Works</h2>
        <p class="mt-3 text-gray-500 max-w-xl mx-auto">Getting connected to the right contractor takes less than two minutes.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {steps.map(s => (
          <div class="relative flex flex-col items-center text-center p-6">
            <div class="w-14 h-14 rounded-full bg-brand flex items-center justify-center text-white font-display text-xl font-bold mb-5 shadow-lg">{s.n}</div>
            <h3 class="font-display text-lg font-semibold text-brand mb-2">{s.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUST PHOTO BAND -->
  <section class="grid md:grid-cols-2 overflow-hidden max-h-72">
    <img src="/images/exterior.webp" alt="Professionally renovated home exterior" class="w-full h-full object-cover" />
    <img src="/images/bathroom.webp" alt="Beautifully remodeled bathroom" class="w-full h-full object-cover" />
  </section>

  <!-- REQUEST FORM -->
  <section class="py-16 md:py-24 bg-light" id="request">
    <div class="container max-w-2xl">
      <div class="text-center mb-10">
        <h2 class="section-title">Get Free Quotes From Local Pros</h2>
        <p class="mt-3 text-gray-500">Tell us what you need and we'll match you with available contractors in your area — completely free.</p>
      </div>
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10">
        <form id="request-form" class="space-y-5" novalidate>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">What service do you need? <span class="text-accent">*</span></label>
            <select name="service" required class="w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-accent">
              <option value="">Select a service...</option>
              <option>Plumbing</option>
              <option>Electrical</option>
              <option>HVAC / Air Conditioning</option>
              <option>Roofing</option>
              <option>Interior Painting</option>
              <option>Exterior Painting</option>
              <option>Kitchen Remodeling</option>
              <option>Bathroom Remodeling</option>
              <option>Flooring</option>
              <option>Landscaping</option>
              <option>General Contractor</option>
              <option>Pest Control</option>
              <option>Other</option>
            </select>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Your Name <span class="text-accent">*</span></label>
              <input name="name" type="text" placeholder="Jane Smith" required class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">ZIP Code <span class="text-accent">*</span></label>
              <input name="zip" type="text" placeholder="55401" inputmode="numeric" maxlength="5" required class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address <span class="text-accent">*</span></label>
            <input name="email" type="email" placeholder="jane@example.com" required class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Briefly describe your project</label>
            <textarea name="message" rows="3" placeholder="E.g. I need my bathroom faucet replaced and there's a slow drain..." class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent resize-none"></textarea>
          </div>
          <div>
            <button type="submit" class="btn-primary w-full text-base py-4">
              Find Contractors in My Area →
            </button>
          </div>
          <p class="text-xs text-center text-gray-400">By submitting, you agree to receive contractor quotes via email. We never sell your data.</p>
        </form>
        <div id="success-msg" class="hidden text-center py-10">
          <div class="text-5xl mb-4">✅</div>
          <h3 class="font-display text-2xl font-bold text-brand mb-2">You're All Set!</h3>
          <p class="text-gray-500">We're matching you with contractors in your area now. You'll hear back within 24 hours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="container">
      <div class="flex flex-wrap justify-center items-center gap-8 text-center">
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">🔒</span>
          <span class="text-xs font-medium text-gray-500">100% Free<br/>No Obligation</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">✅</span>
          <span class="text-xs font-medium text-gray-500">Pre-Screened<br/>Contractors</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">⭐</span>
          <span class="text-xs font-medium text-gray-500">Verified<br/>Reviews</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">⚡</span>
          <span class="text-xs font-medium text-gray-500">Fast<br/>Matching</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">🇺🇸</span>
          <span class="text-xs font-medium text-gray-500">All 50 States<br/>Covered</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-brand text-white py-10">
    <div class="container flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="14" fill="#F97316"/><path d="M8 14.5l4 4 8-9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="font-semibold">The Contractor Services</span>
      </div>
      <p class="text-white/60 text-xs">© {new Date().getFullYear()} TheContractorServices.com. All rights reserved.</p>
      <nav class="flex gap-4 text-white/60 hover:[&>a]:text-white">
        <a href="/privacy" class="text-xs transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-xs transition-colors">Terms of Service</a>
        <a href="#request" class="text-xs transition-colors">Get Quotes</a>
      </nav>
    </div>
  </footer>

  <!-- FORM SCRIPT -->
  <script>
    const form = document.getElementById('request-form');
    const successMsg = document.getElementById('success-msg');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('[type=submit]');
      btn.disabled = true;
      btn.textContent = 'Submitting…';
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('https://formspree.io/f/xwkgzqqk', {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } catch {}
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    });
  </script>
</body>
</html>
